
nextflow_process {

    name "Test Process FMHFUNPROFILER"
    script "../main.nf"
    process "FMHFUNPROFILER"
    tag "modules"
    tag "modules_"
    tag "fmhfunprofiler"

    test("fmhfunprofiler - fastq") {
	setup {

	    run("CONCAT_ALL") {
		script "../../../../subworkflows/local/concatall.nf"
		process {
                    """
                    input[0]= Channel.of([
                    [ id:'test', single_end:false, run_accession:"abc", "db_name":"demo" ], // meta map
			[ file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true) ]])
                    """
		}
            }

	}
        when {
            process {
                """
                input[0]= CONCAT_ALL.out[0]
                input[1] = Channel.of([[db_params:"11 1000"],file(params.pipelines_testdata_base_path + 'funcprofiler/data/database/fmhfunprofiler/KOs_sketched_scaled_1000_demo.sig.zip')])

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }
    test("fmhfunprofiler - fastq - stub") {

        options "-stub"

        when {
            process {
                """
                input[0]= Channel.of([
                    [ id:'test', single_end:true,  "db_name":"demo" ], // meta map
		    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)]])
                input[1] = Channel.of([[db_params:"11 1000"],file(params.pipelines_testdata_base_path + 'funcprofiler/data/database/fmhfunprofiler/KOs_sketched_scaled_1000_demo.sig.zip')])
                """
            }
        }

        then {
	    def lines = path(process.out.ko.get(0)[1]).text
	    assert lines == "11 1000\n"
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
