// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core modules test mifaser
nextflow_process {

    name "Test Process MIFASER"
    script "../main.nf"
    process "MIFASER"

    tag "modules"
    tag "modules_"
    tag "mifaser"

    // TODO nf-core: Change the test name preferably indicating the test-data and file-format used
    setup{
        run("UNTAR") {
            script "modules/nf-core/untar/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [],
                    file('https://github.com/nickp60/test-datasets/raw/refs/heads/funcprofiler/data/database/mifaser/GS-24-all.tar.gz', checkIfExists: true )
                ])
                """
            }
        }
    }
    test("sarscov2 - fastq") {

        // TODO nf-core: If you are created a test for a chained module
        // (the module requires running more than one process to generate the required output)
        // add the 'setup' method here.
        // You can find more information about how to use a 'setup' method in the docs (https://nf-co.re/docs/contributing/modules#steps-for-creating-nf-test-for-chained-modules).

        when {
            process {
                """
                // TODO nf-core: define inputs of the process here. Example:

                input[0] = [
                    [ id:'test', single_end: true  ],
                       [ file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)]]
                input[1] = UNTAR.out.untar.map{ it[1] }
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert file(process.out.multi_ec[0][1]).exists() },
                { assert file(process.out.analysis[0][1]).exists() },
                { assert file(process.out.ec_counts[0][1]).exists() },
                { assert snapshot(
                    file(process.out.multi_ec[0][1]).name,
                    file(process.out.analysis[0][1]).name,
                    file(process.out.ec_counts[0][1]).name,
                    process.out.versions_mifaser
                ).match() }
            )
        }

    }

    // TODO nf-core: Change the test name preferably indicating the test-data and file-format used but keep the " - stub" suffix.
    test("sarscov2 - fastq - stub") {

        options "-stub"

        when {
            process {
                """
                // TODO nf-core: define inputs of the process here. Example:

                input[0] = [
                    [ id:'test', single_end: true ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                ]
                input[1] = UNTAR.out.untar.map{ it[1] }
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert file(process.out.multi_ec[0][1]).exists() },
                { assert file(process.out.analysis[0][1]).exists() },
                { assert file(process.out.ec_counts[0][1]).exists() },
                { assert snapshot(
                    file(process.out.multi_ec[0][1]).name,
                    file(process.out.analysis[0][1]).name,
                    file(process.out.ec_counts[0][1]).name,
                    process.out.versions_mifaser
                ).match() }
            )
        }

    }

}
